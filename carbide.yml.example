# Carbide2 worker configuration
# Copy this to carbide.yml and adjust for your environment.
# carbide.yml is gitignored — never commit it with real paths.

# project_root: the directory used as the working directory for new terminals.
# Defaults to Dir.pwd (wherever the worker is started from) if not set.
# Set this to a safe sandbox directory so terminal PTYs and future on-disk
# sync operations are bounded away from the carbide2-server repo itself.
#
# project_root: /home/yourname/projects/sandbox
project_root:
